import os
import pathlib
import shutil
import subprocess


def remove_standard_flags(flags):
    cxx17_flags = {"/std:c++17", "-std=c++17"}
    return [flag for flag in flags if str(flag) not in cxx17_flags]


def parse_bool_arg(value):
    return str(value).lower() in {"1", "true", "yes", "on"}


with_hosted_tests_arg = parse_bool_arg(ARGUMENTS.pop("with_hosted_tests", ""))
godot_bin_arg = ARGUMENTS.pop("godot_bin", "")


# 1. Setup the basic SCons environment
opts = Variables()
opts.Add(EnumVariable("platform", "The platform to build for", "windows", ["windows", "linux", "macos", "android", "ios"]))
opts.Add(EnumVariable("target", "The target to build for", "template_debug", ["template_debug", "template_release", "editor"]))
opts.Add(EnumVariable("precision", "Floating-point precision", "single", ["single", "double"]))
opts.Add(BoolVariable("with_tidy", "Run clang-tidy alongside compilation", False))

env = Environment(variables=opts)

# Add compilation database tool
env.Tool('compilation_db')

# 2. Import the godot-cpp configuration
# This allows us to use the same compiler flags godot-cpp uses
env = SConscript("../godot-cpp/SConstruct", exports="env")

# 3. Add your local include directory and godot-cpp includes
