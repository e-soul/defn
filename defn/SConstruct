test_support_sources = [
    "src/match_session.cpp",
    "src/combat_logic.cpp",
]

unit_test_sources = [
    "tests/test_main.cpp",
    "tests/test_match_session_core.cpp",
    "tests/test_combat_logic.cpp",
]

if hosted_tests_enabled:
    extension_sources += hosted_test_sources


def object_target_for(source_path, prefix=""):
    obj_name = os.path.splitext(source_path.replace(os.sep, "_").replace("/", "_"))[0]
    return os.path.join(obj_dir, prefix + obj_name)


def resolve_godot_executable(configured_path):
    candidate_paths = [configured_path, os.environ.get("GODOT_BIN", "")]
    for candidate in candidate_paths:
        if candidate and pathlib.Path(candidate).exists():
            return str(pathlib.Path(candidate).resolve())

    for name in ["godot4", "godot"]:
        detected = shutil.which(name)
        if detected:
            return detected

    return None

# 5. Compile into a dedicated object directory
obj_dir = os.path.join("build", "obj")
objects = []
for src in extension_sources:
    obj_target = object_target_for(src)
    objects.append(env.SharedObject(target=obj_target, source=src))

# 6. Build the Shared Library (The DLL)
library = env.SharedLibrary(
    target="bin/defn_core" + env["suffix"] + env["SHLIBSUFFIX"],
    source=objects,
)

# 7. Clang-Tidy alias and dependency
if env.get("with_tidy", False) or "tidy" in COMMAND_LINE_TARGETS:
    comp_db = env.Alias('compilation_db', 'compile_commands.json')
    tidy_targets = []
    for src in extension_sources:
        action = Action('clang-tidy --quiet -p . $SOURCE', 'Running clang-tidy on $SOURCE')
        tidy_node = env.Command(src + ".tidy", [src, comp_db], action)
        tidy_targets.append(tidy_node)

    env.Alias('tidy', tidy_targets)
    if env.get("with_tidy", False):
        env.Depends(library, tidy_targets)

test_env = env.Clone()
test_env.Append(CPPPATH=["tests/"])
test_objects = []
for src in test_support_sources + unit_test_sources:
    test_objects.append(test_env.Object(target=object_target_for(src, prefix="native_"), source=src))

test_program = test_env.Program(
    target=os.path.join("bin", "defn_unit_tests"),
    source=test_objects,
)


def run_unit_tests(target, source, env):
    result = subprocess.run([str(source[0].abspath)], check=False)
    target_path = pathlib.Path(str(target[0]))
    target_path.parent.mkdir(parents=True, exist_ok=True)
    target_path.write_text(str(result.returncode), encoding="ascii")
    return result.returncode


test_stamp = env.Command(os.path.join("build", "defn_unit_tests.stamp"), test_program, run_unit_tests)
AlwaysBuild(test_stamp)
env.Alias("unit_tests", test_program)
env.Alias("test", test_stamp)


def run_hosted_tests(target, source, env):
    godot_executable = resolve_godot_executable(env.get("DEFN_GODOT_BIN", ""))
    if not godot_executable:
        print("Unable to locate Godot. Set godot_bin=<path> or GODOT_BIN to run hosted tests.")
        return 1

    project_dir = pathlib.Path(".").resolve()
    script_path = project_dir / "tests" / "godot_hosted_runner.gd"
    result = subprocess.run(
        [godot_executable, "--headless", "--path", str(project_dir), "--script", str(script_path)],
        check=False,
        cwd=project_dir,
    )
    target_path = pathlib.Path(str(target[0]))
    target_path.parent.mkdir(parents=True, exist_ok=True)
    target_path.write_text(str(result.returncode), encoding="ascii")
    return result.returncode


hosted_test_script = os.path.join("tests", "godot_hosted_runner.gd")
hosted_test_stamp = env.Command(os.path.join("build", "defn_hosted_tests.stamp"), [library, hosted_test_script], run_hosted_tests)
AlwaysBuild(hosted_test_stamp)
env.Alias("hosted_test", hosted_test_stamp)
env.Alias("test_all", [test_stamp, hosted_test_stamp])

Default(library)
