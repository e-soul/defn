    "src/content_validator.cpp",
    "src/hitbox_component.cpp",
    "src/level_loader.cpp",
    "src/camera_scroll_controller.cpp",
    "src/game_background_builder.cpp",
    "src/menu_data_loader.cpp",
    "src/menu_style.cpp",
    "src/settings_service.cpp",
    "src/scene_navigator.cpp",
